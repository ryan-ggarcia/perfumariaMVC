<main class="px-6 lg:px-10 py-8 space-y-8">

    <!-- Boas-vindas -->
    <section class="animate-fade-up">
        <h1 class="font-serif text-3xl md:text-4xl">
            Olá, <span class="text-primary">
                <%= user.name %>
            </span>!
        </h1>
        <p class="text-muted mt-2">Aqui está o resumo da sua perfumaria</p>
    </section>

    <!-- Cards de métricas -->
    <section id="stats-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
        <% stats.forEach(function(stat, i) { %>
            <article
                class="stat-card group relative overflow-hidden rounded-2xl bg-surface border border-border/60 p-6 shadow-card animate-fade-up"
                style="animation-delay: 0ms">
                <div
                    class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-primary/10 blur-2xl group-hover:bg-primary/20 transition-colors">
                </div>
                <div class="relative flex items-start justify-between">
                    <div>
                        <p class="text-xs uppercase tracking-[0.18em] text-muted">
                            <%= stat.title %>
                        </p>
                        <p class="mt-3 font-serif text-3xl">
                            <%= stat.value %>
                        </p>
                        <p class="mt-2 text-xs font-medium <%= stat.positive ? 'text-success' : 'text-red-400' %>">
                            <%= stat.delta %>
                        </p>
                    </div>
                    <div
                        class="h-11 w-11 rounded-xl bg-gradient-to-br from-primary to-surface2 flex items-center justify-center shadow-card">
                        <i class="icon-<%= stat.icon %> text-white"></i>
                    </div>
                </div>
            </article>
            <% }) %>
    </section>

    <!-- Gráficos -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 chart-card rounded-2xl bg-surface border border-border/60 p-6 shadow-card animate-fade-up"
            style="animation-delay:400ms">
            <div class="mb-5">
                <h3 class="font-serif text-lg">Vendas ao Longo do Tempo</h3>
                <p class="text-xs text-muted mt-0.5">Últimos 8 meses</p>
            </div>
            <div class="h-64"><canvas id="salesChart"></canvas></div>
        </div>

        <div class="chart-card rounded-2xl bg-surface border border-border/60 p-6 shadow-card animate-fade-up"
            style="animation-delay:500ms">
            <div class="mb-5">
                <h3 class="font-serif text-lg">Comparativo de Compras</h3>
                <p class="text-xs text-muted mt-0.5">Compras vs Vendas</p>
            </div>
            <div class="h-64"><canvas id="purchasesChart"></canvas></div>
        </div>

        <div class="lg:col-span-3 chart-card rounded-2xl bg-surface border border-border/60 p-6 shadow-card animate-fade-up"
            style="animation-delay:600ms">
            <div class="mb-5">
                <h3 class="font-serif text-lg">Categorias de Perfumes</h3>
                <p class="text-xs text-muted mt-0.5">Distribuição por família olfativa</p>
            </div>
            <div class="h-64"><canvas id="categoryChart"></canvas></div>
        </div>
    </section>

    <!-- Tabela de produtos recentes -->
    <section class="rounded-2xl bg-surface border border-border/60 shadow-card animate-fade-up overflow-hidden"
        style="animation-delay:700ms">
        <div class="px-6 py-5 flex items-center justify-between border-b border-border/60">
            <div>
                <h3 class="font-serif text-lg">Produtos Recentes</h3>
                <p class="text-xs text-muted mt-0.5">Últimos cadastros do catálogo</p>
            </div>
            <button class="text-xs font-medium text-primary hover:underline">Ver todos</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-muted uppercase text-[11px] tracking-wider border-b border-border/60">
                        <th class="px-6 py-3 font-medium">Nome</th>
                        <th class="px-6 py-3 font-medium">Categoria</th>
                        <th class="px-6 py-3 font-medium">Preço</th>
                        <th class="px-6 py-3 font-medium">Estoque</th>
                        <th class="px-6 py-3 font-medium">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(p) { %>
                        <tr class="border-b border-border/30 hover:bg-bg/40 transition-colors">
                            <td class="px-6 py-4 font-medium">
                                <%= p.name %>
                            </td>
                            <td class="px-6 py-4 text-muted">
                                <%= p.category %>
                            </td>
                            <td class="px-6 py-4">R$ <%= p.price.toFixed(2).replace('.', ',' ) %>
                            </td>
                            <td class="px-6 py-4">
                                <%= p.stock %>
                            </td>
                            <td class="px-6 py-4">
                                <% var s=p.status; %>
                                    <% var cls=s==='Disponível' ? 'bg-success/20 text-success border-success/30' :
                                        s==='Estoque baixo' ? 'bg-primary/20 text-primary border-primary/40'
                                        : 'bg-red-500/15 text-red-300 border-red-400/30' ; %>
                                        <span
                                            class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-medium border <%= cls %>">
                                            <%= s %>
                                        </span>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </section>

    <footer class="pt-4 pb-2 text-center text-xs text-muted">
        Al-Nour Perfumaria • Painel Administrativo
    </footer>
</main>