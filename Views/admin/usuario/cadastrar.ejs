
    <link rel="stylesheet" href="/css/style-user.css" />
     <div class="with-sidebar" style="padding-left:256px">

    <main style="padding: 36px 28px; display:flex; flex-direction:column; gap:28px; justify-content: center;">
      <section class="fade-up" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px">
        <div>
          <h1 class="font-serif" style="margin:0;font-size:36px">Gestão de <span style="color:var(--primary)">Usuários</span></h1>
          <p style="margin:8px 0 0;color:var(--muted)">Cadastre e gerencie acessos ao painel administrativo</p>
        </div>
        <button class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg bg-gradient-to-r from-primary to-surface2 text-white text-sm font-medium shadow-card hover:-translate-y-0.5 transition" id="openModal">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          Novo Usuário
        </button>
      </section>

      <section class="surface fade-up" style="overflow:hidden">
        <div style="padding:16px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <h2 class="font-serif" style="margin:0;font-size:18px">Usuários cadastrados</h2>
          <span id="count" style="margin-left:auto;font-size:12px;color:var(--muted)">0 registros</span>
        </div>
        <div style="overflow-x:auto">
          <table class="table">
            <thead>
              <th>
                Nome
              </th>
              <th>
                Email
              </th>
              <th>
                Perfil
              </th>
              <th>
                Ações
              </th>
            </thead>
            <tbody id="usersBody">
              <%if(user.length > 0){%>
                <% user.forEach(u =>{ %>
                  <tr>

                    <td><%= u.usu_nome %></td>
                    <td><%= u.usu_email %></td>
                    <td><%= u.usu_perfil_desc %></td>
                    <td>
                      <button class="bg-blue-500 text-white px-4 py-2 rounded hover:-translate-y-0.5 transition" value="<%=u.usu_id%>"><i class="fi fi-rr-pencil"></i></button>
                      <button class="bg-red-500 text-white px-4 py-2 rounded hover:-translate-y-0.5 transition" value="<%=u.usu_id%>"><i class="fi fi-rs-delete-user"></i></button>
                    </td>
                  </tr>
                <% }) %>
              <%} else{%>
                <tr>
                  <td colspan="4" style="text-align:center;padding:20px;color:var(--muted)">Nenhum usuário cadastrado</td>
                </tr>
              <%}%>
            </tbody>
          </table>
        </div>
      </section>

      <footer style="text-align:center;font-size:12px;color:var(--muted);padding:8px 0 4px">
        Al-Nour Perfumaria • Painel Administrativo
      </footer>
    </main>
  </div>

  <!-- Modal: Cadastrar usuário -->
  <div class="modal-backdrop" id="modal" role="dialog" aria-modal="true">
    <div class="modal">
      <h3 class="font-serif">Cadastrar <span style="color:var(--primary)">usuário</span></h3>
      <p class="desc">Preencha os dados para registrar um novo acesso ao painel.</p>
      <form id="adminForm" novalidate>
        <div style="margin-bottom:12px">
          <label class="label" for="a-nome">Nome</label>
          <div class="field">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <input class="input" id="a-nome" type="text" placeholder="Nome completo" maxlength="255" required />
          </div>
        </div>
        <div style="margin-bottom:12px">
          <label class="label" for="a-email">E-mail</label>
          <div class="field">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
            <input class="input" id="a-email" type="email" placeholder="usuario@alnour.com" maxlength="255" required />
          </div>
        </div>
        <div style="margin-bottom:12px">
          <label class="label" for="a-password">Senha</label>
          <div class="field">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input class="input" id="a-password" type="password" placeholder="Mínimo 8 caracteres" maxlength="72" required />
            <button type="button" class="toggle" onclick="togglePassword('a-password', this)" aria-label="Mostrar senha">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div style="margin-bottom:12px">
          <label class="label" for="a-dob">Data de nascimento</label>
          <div class="field">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <input class="input" id="a-dob" type="date" required />
          </div>
        </div>
        <div style="margin-bottom:18px">
          <label class="label" for="a-profile">Tipo de perfil</label>
          <div class="field">
            <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <select class="select" id="a-profile" required>
              <option value="0">Selecione um perfil</option>
              <% perfil.forEach(p =>{ %> 
                <option value="<%= p.per_id%>"><%= p.per_desc %></option>
              <%})%>
            </select>
          </div>
        </div>
        <div class="row">
          <button type="button" class="btn btn-outline" id="closeModal">Cancelar</button>
          <button type="button" class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg bg-gradient-to-r from-primary to-surface2 text-white text-sm font-medium shadow-card hover:-translate-y-0.5 transition btnGravar">Cadastrar</button>
        </div>
      </form>
    </div>
  </div>
  
  <script src="/js/usuario/fetchCadastrar.js" ></script>
  <script src="/js/usuario/usuScript.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>